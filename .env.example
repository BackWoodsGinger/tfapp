# Copy to .env and adjust before: docker compose up --build

DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,tfapp.freedomwoods.online,192.168.1.192
DJANGO_CSRF_TRUSTED_ORIGINS=https://tfapp.freedomwoods.online,http://localhost:8000,http://192.168.1.192:8000
DJANGO_SECURE_PROXY_SSL_HEADER=1
DJANGO_USE_WHITENOISE=1

POSTGRES_DB=tfapp
POSTGRES_USER=tfapp
POSTGRES_PASSWORD=change-me

WEB_PORT=8000

# Optional email (same vars as settings.py)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=

# Session timeout (seconds). Default 5400 = 90 minutes of inactivity.
# SESSION_COOKIE_AGE=5400
# DJANGO_SESSION_SAVE_EVERY_REQUEST=1
# DJANGO_MAX_SESSIONS_PER_USER=3

# Only if a trusted reverse proxy sets X-Forwarded-For (for kiosk IP matching).
# DJANGO_TRUST_X_FORWARDED_FOR=1
